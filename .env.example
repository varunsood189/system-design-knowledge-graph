# =============================================================================
# TEMPLATE ONLY — copy to `.env` and fill in real values.
# Never put real keys in this file; it may be committed to git.
# =============================================================================

# -----------------------------------------------------------------------------
# This app (system-design-knowledge-graph)
# -----------------------------------------------------------------------------
# Option A: call Gemini directly (skips gateway when key is set)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite

# Option B: use LLM Gateway V2 (start llm_gatewayV2 on port 8100 first)
# Leave GEMINI_API_KEY empty in THIS file when using gateway-only from the app.
# LLM_BASE_URL=http://127.0.0.1:8100
# LLM_GATEWAY_API=v2
# LLM_MODEL=gemini-2.5-flash-lite
# LLM_PROVIDER=
# LLM_CACHE_SYSTEM=true
# LLM_REASONING=off
# LLM_MAX_TOKENS=8192

# -----------------------------------------------------------------------------
# LLM Gateway providers (for llm_gateway / llm_gatewayV2)
# Usually live in Assignment 5/.env (parent of gateway folder).
# Gateway reads ../.env — you can duplicate here for local dev only in `.env`.
# -----------------------------------------------------------------------------

# Gemini
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash-lite

# NVIDIA NIM
# NVIDIA_API_KEY=
# NVIDIA_MODEL=deepseek-ai/deepseek-v4-pro

# Groq
# GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile

# Cerebras
# CEREBRAS_API_KEY=
# CEREBRAS_MODEL=qwen-3-235b-a22b-instruct-2507

# OpenRouter
# OPEN_ROUTER_API_KEY=
# OPENROUTER_MODEL=nvidia/nemotron-3-super-120b-a12b:free

# GitHub Models
# GITHUB_ACCESS_TOKEN=
# GITHUB_MODEL=openai/gpt-4.1-mini

# Ollama (local)
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=gemma4:31b

# Gateway routing (V1 default port 8099, V2 uses GATEWAY_V2_PORT=8100)
# LLM_ORDER=ollama,gemini,nvidia,groq,cerebras,openrouter,github
# GATEWAY_PORT=8099
# GATEWAY_V2_PORT=8100
