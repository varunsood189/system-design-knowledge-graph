# =============================================================================
# TEMPLATE ONLY — copy to `.env` and fill in real values.
# Never put real keys in this file; it may be committed to git.
# =============================================================================

# -----------------------------------------------------------------------------
# This app (system-design-knowledge-graph)
# -----------------------------------------------------------------------------
# LLM orchestrator: Gemini JSON planner + fastmcp (ownership-demo style)
USE_AGENT_ORCHESTRATOR=true
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
AGENT_MAX_TURNS=12
# AGENT_DEBUG=true
LOG_LEVEL=INFO

# Inner agents (concepts/relationships inside MCP tools): direct Gemini or gateway
# LLM_BASE_URL=http://127.0.0.1:8100
# LLM_GATEWAY_API=v2
# LLM_MODEL=gemini-2.5-flash-lite
# LLM_PROVIDER=
# LLM_CACHE_SYSTEM=true
# LLM_REASONING=off
# LLM_MAX_TOKENS=8192

# -----------------------------------------------------------------------------
# LLM Gateway providers (optional — for llm_gateway / llm_gatewayV2)
# Keep real keys in your local gitignored `.env` only.
# -----------------------------------------------------------------------------

# Gemini
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash-lite

# NVIDIA NIM
# NVIDIA_API_KEY=
# NVIDIA_MODEL=deepseek-ai/deepseek-v4-pro

# Groq
# GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile

# Cerebras
# CEREBRAS_API_KEY=
# CEREBRAS_MODEL=qwen-3-235b-a22b-instruct-2507

# OpenRouter
# OPEN_ROUTER_API_KEY=
# OPENROUTER_MODEL=nvidia/nemotron-3-super-120b-a12b:free

# GitHub Models
# GITHUB_ACCESS_TOKEN=
# GITHUB_MODEL=openai/gpt-4.1-mini

# Ollama (local)
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=gemma4:31b

# Gateway routing (V1 default port 8099, V2 uses GATEWAY_V2_PORT=8100)
# LLM_ORDER=ollama,gemini,nvidia,groq,cerebras,openrouter,github
# GATEWAY_PORT=8099
# GATEWAY_V2_PORT=8100
